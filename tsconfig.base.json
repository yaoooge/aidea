{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@ail/shared": [
        "packages/shared/src"
      ],
      "@ail/config": [
        "packages/config/src"
      ],
      "@ail/ui": [
        "packages/ui/src"
      ]
    }
  }
}
