# 根目录环境变量说明（复制为 .env 或 .env.local 使用，勿提交密钥）
#
# 后端 API（apps/api）
PORT=3000
# M2：数据库固定为 PostgreSQL（见 docs/m2/design-prerequisites.md）
DATABASE_URL=postgresql://user:pass@localhost:5432/aidea
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=24h

# 前端（apps/client H5，可选）
# VITE_API_BASE_URL=http://localhost:3000
